generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MEMBER
  MODERATOR
  ADMIN
}

enum ContentType {
  BIBLE
  SERMON
  PRAYER_REQUEST
  TESTIMONY
  EVENT
  GROUP_POST
  ANNOUNCEMENT
  LOCATION
  DOWNLOAD
}

enum SermonLanguage {
  ENGLISH
  OTHER
}

enum ReadingPlanType {
  BIBLE
  SERMON
  COMBINED
}

enum PrayerStatus {
  OPEN
  ANSWERED
  HIDDEN
}

enum TestimonyStatus {
  PENDING
  PUBLISHED
  REJECTED
}

enum GroupType {
  LOCAL
  STUDY
  PRAYER
  DISCUSSION
}

enum EventStatus {
  UPCOMING
  LIVE
  COMPLETED
  CANCELLED
}

enum RsvpStatus {
  GOING
  INTERESTED
  NOT_GOING
}

enum LocationType {
  ASSEMBLY
  HOUSE_FELLOWSHIP
  MINISTER
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                     String              @id @default(cuid())
  name                   String
  email                  String?             @unique
  passwordHash           String?
  role                   UserRole            @default(MEMBER)
  avatarUrl              String?
  bio                    String?
  location               String?
  churchName             String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  bookmarks              Bookmark[]
  notes                  Note[]
  highlights             Highlight[]
  prayerRequests         PrayerRequest[]
  prayerResponses        PrayerResponse[]
  testimonies            Testimony[]
  createdGroups          FellowshipGroup[]    @relation("GroupCreatedBy")
  fellowshipMemberships   FellowshipMember[]
  groupPosts             GroupPost[]
  eventRsvps             EventRsvp[]
  downloads              Download[]
  announcementsCreated   Announcement[]       @relation("AnnouncementCreatedBy")
  eventsCreated          Event[]              @relation("EventCreatedBy")
  moderatedItems         ModerationQueue[]    @relation("ModeratedBy")
}

model BibleBook {
  id          String         @id @default(cuid())
  name        String         @unique
  shortName   String         @unique
  order       Int            @unique
  testament   String
  chapters    BibleChapter[]
  verses      BibleVerse[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model BibleChapter {
  id            String       @id @default(cuid())
  bookId        String
  chapterNumber Int
  verseCount    Int
  book          BibleBook    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  verses        BibleVerse[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([bookId, chapterNumber])
  @@index([bookId])
}

model BibleVerse {
  id             String      @id @default(cuid())
  bookId         String
  chapterId      String
  verseNumber    Int
  text           String
  kjvText        String
  crossReferences Json?
  book           BibleBook   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter        BibleChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([chapterId, verseNumber])
  @@index([bookId])
  @@index([chapterId])
}

model Sermon {
  id                  String          @id @default(cuid())
  title               String
  slug                String          @unique
  preacherName        String          @default("William Marrion Branham")
  datePreached        DateTime
  audioUrl            String?
  transcript          String
  summary             String?
  theme               String?
  tags                String[]
  scriptureReferences  Json?
  seriesName          String?
  duration            Int?
  language            SermonLanguage  @default(ENGLISH)
  featured            Boolean         @default(false)
  sourceUrl           String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  topicMaps           SermonTopicMap[]
}

model SermonTopic {
  id         String           @id @default(cuid())
  name       String           @unique
  slug       String           @unique
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  sermonMaps SermonTopicMap[]
}

model SermonTopicMap {
  sermonId  String
  topicId   String
  sermon    Sermon       @relation(fields: [sermonId], references: [id], onDelete: Cascade)
  topic     SermonTopic   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@id([sermonId, topicId])
  @@index([topicId])
}

model ReadingPlan {
  id          String            @id @default(cuid())
  name        String
  description String?
  type        ReadingPlanType
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  items       ReadingPlanItem[]
}

model ReadingPlanItem {
  id           String        @id @default(cuid())
  planId       String
  dayNumber    Int
  orderIndex   Int           @default(0)
  contentType  ContentType
  contentId    String
  plan         ReadingPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([planId, dayNumber, orderIndex])
  @@index([planId])
  @@index([contentType, contentId])
}

model Bookmark {
  id          String       @id @default(cuid())
  userId      String
  contentType ContentType
  contentId   String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())

  @@unique([userId, contentType, contentId])
  @@index([contentType, contentId])
}

model Note {
  id          String       @id @default(cuid())
  userId      String
  contentType ContentType
  contentId   String
  body        String
  verseRange  String?
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId, contentType])
  @@index([contentType, contentId])
}

model Highlight {
  id           String       @id @default(cuid())
  userId       String
  contentType  ContentType
  contentId    String
  selectedText String
  color        String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())

  @@index([userId, contentType])
  @@index([contentType, contentId])
}

model PrayerRequest {
  id           String           @id @default(cuid())
  userId       String?
  title        String
  body         String
  status       PrayerStatus     @default(OPEN)
  isAnonymous  Boolean          @default(false)
  prayCount    Int              @default(0)
  answeredAt   DateTime?
  user         User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  responses    PrayerResponse[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([status])
  @@index([userId])
}

model PrayerResponse {
  id          String         @id @default(cuid())
  requestId   String
  userId      String?
  body        String
  request     PrayerRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())

  @@index([requestId])
  @@index([userId])
}

model Testimony {
  id          String          @id @default(cuid())
  userId      String?
  title       String
  body        String
  status      TestimonyStatus @default(PENDING)
  isFeatured  Boolean         @default(false)
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([status])
  @@index([userId])
}

model FellowshipGroup {
  id          String             @id @default(cuid())
  name        String
  slug        String             @unique
  description String?
  region      String?
  type        GroupType
  createdById String?
  createdBy   User?              @relation("GroupCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  members     FellowshipMember[]
  posts       GroupPost[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([type])
  @@index([region])
}

model FellowshipMember {
  id        String            @id @default(cuid())
  groupId   String
  userId    String
  role      String            @default("member")
  group     FellowshipGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime          @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

model GroupPost {
  id          String            @id @default(cuid())
  groupId     String
  userId      String
  body        String
  group       FellowshipGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([groupId])
  @@index([userId])
}

model Event {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  description  String?
  eventType    String
  status       EventStatus   @default(UPCOMING)
  startsAt     DateTime
  endsAt       DateTime?
  locationName String?
  address      String?
  isLivestream Boolean       @default(false)
  streamUrl    String?
  createdById  String?
  creator      User?         @relation("EventCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  rsvps        EventRsvp[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
  @@index([startsAt])
}

model EventRsvp {
  id        String     @id @default(cuid())
  eventId   String
  userId    String
  status    RsvpStatus @default(GOING)
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([eventId, userId])
  @@index([userId])
}

model Location {
  id          String         @id @default(cuid())
  name        String
  type        LocationType
  region      String?
  address     String?
  phone       String?
  email       String?
  latitude    Decimal?       @db.Decimal(10, 7)
  longitude   Decimal?       @db.Decimal(10, 7)
  serviceTimes Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([type])
  @@index([region])
}

model Download {
  id           String       @id @default(cuid())
  userId       String
  contentType  ContentType
  contentId    String
  downloadedAt DateTime     @default(now())
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentType, contentId])
  @@index([contentType, contentId])
}

model Announcement {
  id           String        @id @default(cuid())
  title        String
  body         String
  audience     String?
  publishedAt  DateTime?
  createdById  String?
  creator      User?         @relation("AnnouncementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([publishedAt])
}

model ModerationQueue {
  id            String            @id @default(cuid())
  itemType      ContentType
  itemId        String
  status        ModerationStatus   @default(PENDING)
  reason        String?
  moderatedById String?
  moderator     User?              @relation("ModeratedBy", fields: [moderatedById], references: [id], onDelete: SetNull)
  moderatedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([itemType, itemId])
  @@index([status])
}
